# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production example:
# DJANGO_ALLOWED_HOSTS=milkman-02fj.onrender.com
TRUST_PROXY_SSL_HEADER=false
USE_X_FORWARDED_HOST=false
SECURE_SSL_REDIRECT=false

# Production database (recommended for Render + Supabase)
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:[password]@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=
DATABASE_SSL_REQUIRE=false
DATABASE_CONN_MAX_AGE=600

# Local SQL Server fallback (used only when DATABASE_URL is empty)
DB_NAME=milkMan
DB_HOST=localhost
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# If true, Django will use Windows Integrated Security via ODBC Trusted_Connection
DB_TRUSTED_CONNECTION=true

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Production example:
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Developer review / notifications
# On hosting behind Nginx/Render/other proxies, set DEVELOPER_TRUST_X_FORWARDED_FOR=true
# and put your office/public IPs here.
DEVELOPER_ALLOWED_IPS=127.0.0.1,::1
DEVELOPER_TRUST_X_FORWARDED_FOR=false
DEVELOPER_EMAILS=
DEVELOPER_TOKEN_MAX_AGE_SECONDS=43200

# CORS dev convenience (allow any localhost port)
DEV_ALLOW_ALL_LOCALHOST_ORIGINS=true

# Session (security)
# Recommended: do not persist login after browser is closed.
SESSION_EXPIRE_AT_BROWSER_CLOSE=true
# Auto-logout after inactivity (seconds). Example: 6 hours
SESSION_COOKIE_AGE=21600
SESSION_SAVE_EVERY_REQUEST=true
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
ADMIN_MAX_FAILED_LOGIN_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=30
AUTH_TOKEN_MAX_AGE_SECONDS=604800

# Email (Gmail SMTP example)
# Create an App Password in your Google Account and use it below.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=MilkMan <your_gmail@gmail.com>

# Dev only: return OTP in API responses for testing
DEV_RETURN_OTPS=false

# SMS (optional)
# Default is console logging in DEBUG mode.
SMS_BACKEND=console

# Twilio (trial works; configure and set SMS_BACKEND=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
